<Window x:Class="SteamRoulette.Views.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Please Wait"
        Width="340" Height="110"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <StackPanel Margin="14,10">
    <TextBlock x:Name="StatusLabel" Text="Please wait…" FontSize="12" Margin="0,0,0,10"
               TextWrapping="Wrap"/>
    <ProgressBar x:Name="Bar" Height="18" IsIndeterminate="True"/>
  </StackPanel>
</Window>
