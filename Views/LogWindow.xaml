<Window x:Class="SteamRoulette.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log"
        Width="720" Height="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Closing="LogWindow_Closing">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,6,6,2">
      <Button x:Name="BtnClear"   Content="Clear"    Width="60"  Height="24" Margin="0,0,6,0" Click="BtnClear_Click"/>
      <Button x:Name="BtnCopyAll" Content="Copy All" Width="70"  Height="24" Click="BtnCopyAll_Click"/>
    </StackPanel>

    <TextBox x:Name="LogText"
             Grid.Row="1"
             Margin="6,0,6,6"
             IsReadOnly="True"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             FontFamily="Courier New"
             FontSize="9"
             TextWrapping="Wrap"
             AcceptsReturn="True"/>
  </Grid>
</Window>
