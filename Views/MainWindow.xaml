<Window x:Class="SteamRoulette.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Roulette"
        Width="620" Height="780"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{Binding WindowBackground}">

  <Window.Resources>
    <!-- Button style -->
    <Style TargetType="Button" x:Key="AppButton">
      <Setter Property="Background"   Value="{Binding WindowBackground}"/>
      <Setter Property="Foreground"   Value="{Binding WindowForeground}"/>
      <Setter Property="BorderBrush"  Value="{Binding WindowForeground}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"      Value="6,3"/>
      <Setter Property="Cursor"       Value="Hand"/>
    </Style>

    <Style TargetType="CheckBox" x:Key="AppCheckBox">
      <Setter Property="Foreground" Value="{Binding WindowForeground}"/>
      <Setter Property="Background" Value="{Binding WindowBackground}"/>
    </Style>
  </Window.Resources>

  <Grid>
    <!-- Logo (top-left) — loaded from embedded assembly resource via pack URI -->
    <Image Source="pack://application:,,,/Resources/SteamRouletteLogo.png"
           Width="120" Height="50"
           HorizontalAlignment="Left" VerticalAlignment="Top"
           Margin="5,5,0,0" Stretch="Uniform"/>

    <!-- Copyright -->
    <TextBlock Text="© Streetbackguy 2024"
               FontSize="9"
               Foreground="{Binding WindowForeground}"
               HorizontalAlignment="Left" VerticalAlignment="Top"
               Margin="5,58,0,0"/>

    <!-- Main content stack -->
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,90,0,0">

      <!-- Status label -->
      <TextBlock x:Name="StatusLabel"
                 Text="{Binding StatusText}"
                 FontSize="16"
                 Foreground="{Binding WindowForeground}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"/>

      <!-- Selected game name -->
      <TextBlock x:Name="GameNameLabel"
                 Text="{Binding GameNameText}"
                 FontSize="16"
                 Foreground="{Binding WindowForeground}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 MaxWidth="420"
                 Margin="0,4,0,0"/>

      <!-- Canvas / banner area -->
      <Border Width="600" Height="300" Background="Black" Margin="0,8,0,0" ClipToBounds="True">
        <Canvas x:Name="SpinCanvas" Width="600" Height="300" ClipToBounds="True">
          <!-- Spin images are added programmatically -->
          <Image x:Name="StaticHeaderImage"
                 Width="600" Height="300"
                 Stretch="Fill"
                 Source="{Binding HeaderImage}"
                 Canvas.Left="0" Canvas.Top="0"/>
        </Canvas>
      </Border>

      <!-- Spin / launch / store buttons -->
      <StackPanel Margin="0,8,0,0" HorizontalAlignment="Center">
        <Button x:Name="BtnSpin"
                Content="Spin the Wheel"
                FontSize="14"
                Width="220" Height="40"
                Style="{StaticResource AppButton}"
                IsEnabled="{Binding CanSpin}"
                Click="BtnSpin_Click"
                HorizontalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
          <Button x:Name="BtnLaunch"
                  Content="Launch/Install Game"
                  FontSize="10"
                  Width="160" Height="30"
                  Margin="0,0,8,0"
                  Style="{StaticResource AppButton}"
                  IsEnabled="{Binding CanLaunch}"
                  Click="BtnLaunch_Click"/>
          <Button x:Name="BtnStore"
                  Content="Steam Storepage"
                  FontSize="10"
                  Width="140" Height="30"
                  Style="{StaticResource AppButton}"
                  IsEnabled="{Binding CanLaunch}"
                  Click="BtnStore_Click"/>
        </StackPanel>
      </StackPanel>

      <!-- Number-of-games controls -->
      <StackPanel HorizontalAlignment="Center" Margin="0,14,0,0">
        <Button Content="Set Number of Games"
                Style="{StaticResource AppButton}"
                Width="160" Height="26"
                HorizontalAlignment="Center"
                Click="BtnSetNumGames_Click"/>
        <TextBlock Text="{Binding NumGamesLabel}"
                   FontSize="9"
                   Foreground="{Binding WindowForeground}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,2,0,0"/>
        <Button Content="Exclude Games"
                FontSize="10"
                Style="{StaticResource AppButton}"
                Width="130" Height="26"
                HorizontalAlignment="Center"
                Margin="0,4,0,0"
                Click="BtnExclude_Click"/>
        <TextBlock Text="{Binding ExcludedCount}"
                   FontSize="9"
                   Foreground="{Binding WindowForeground}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,2,0,0"/>
      </StackPanel>

    </StackPanel>

    <!-- Bottom-left button bar -->
    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="4,0,0,4">
      <StackPanel Orientation="Horizontal">
        <Button Content="Set API Key"          Width="110" Height="26" Margin="2" Style="{StaticResource AppButton}" Click="BtnApiKey_Click"/>
        <Button Content="Set Steam User ID"    Width="120" Height="26" Margin="2" Style="{StaticResource AppButton}" Click="BtnUserId_Click"/>
        <Button Content="Toggle Dark Mode"     Width="120" Height="26" Margin="2" Style="{StaticResource AppButton}" Click="BtnDarkMode_Click"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal">
        <Button Content="Set SteamGridDB Key"  Width="140" Height="26" Margin="2" Style="{StaticResource AppButton}" Click="BtnSgdbKey_Click"/>
        <Button Content="Clear Image Cache"    Width="120" Height="26" Margin="2" Style="{StaticResource AppButton}" Click="BtnClearCache_Click"/>
        <Button Content="Log Window"           Width="88"  Height="26" Margin="2" Style="{StaticResource AppButton}" Click="BtnLog_Click"/>
      </StackPanel>
    </StackPanel>

    <!-- Bottom-right status / checkboxes -->
    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,4,4">
      <!-- Progress bar + status text shown during long operations -->
      <ProgressBar Width="190" Height="10"
                   Minimum="0"
                   Maximum="{Binding ProgressMax, Mode=OneWay}"
                   Value="{Binding ProgressValue, Mode=OneWay}"
                   IsIndeterminate="{Binding ProgressIndeterminate, Mode=OneWay}"
                   Visibility="{Binding ProgressVisibility, Mode=OneWay}"
                   HorizontalAlignment="Right"
                   Margin="0,0,0,3"/>
      <TextBlock x:Name="PleaseWaitLabel"
                 Text="{Binding PleaseWaitText}"
                 FontSize="9"
                 Foreground="{Binding WindowForeground}"
                 HorizontalAlignment="Right"
                 TextWrapping="Wrap" MaxWidth="190"/>
      <TextBlock Text="{Binding GameCountText}"
                 FontSize="9"
                 Foreground="{Binding WindowForeground}"
                 HorizontalAlignment="Right"
                 Margin="0,0,0,4"/>
      <CheckBox x:Name="ChkUninstalled"
                Content="Include Uninstalled Games"
                Style="{StaticResource AppCheckBox}"
                IsChecked="{Binding IncludeUninstalled, Mode=TwoWay}"
                HorizontalAlignment="Right"
                Checked="ChkUninstalled_Changed"
                Unchecked="ChkUninstalled_Changed"/>
      <CheckBox x:Name="ChkAchievements"
                Content="Exclude 100% Achieved Games"
                Style="{StaticResource AppCheckBox}"
                IsChecked="{Binding FilterAchievements, Mode=TwoWay}"
                HorizontalAlignment="Right"
                Checked="ChkAchievements_Changed"
                Unchecked="ChkAchievements_Changed"/>
    </StackPanel>

  </Grid>
</Window>
