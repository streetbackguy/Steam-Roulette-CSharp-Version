<Window x:Class="SteamRoulette.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Roulette"
        Width="480" Height="260"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

  <Window.Background>
    <SolidColorBrush Color="#FF1B2838"/>
  </Window.Background>

  <!-- Thin accent border around the whole window -->
  <Border BorderBrush="#FF4C6B8A" BorderThickness="1" CornerRadius="4">
    <Grid Margin="28,24,28,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>  <!-- logo           -->
        <RowDefinition Height="*"/>     <!-- spacer         -->
        <RowDefinition Height="Auto"/>  <!-- status text    -->
        <RowDefinition Height="8"/>     <!-- gap            -->
        <RowDefinition Height="14"/>    <!-- progress bar   -->
        <RowDefinition Height="6"/>     <!-- gap            -->
        <RowDefinition Height="Auto"/>  <!-- counter text   -->
      </Grid.RowDefinitions>

      <!-- Logo -->
      <Image Grid.Row="0"
             Source="pack://application:,,,/Resources/SteamRouletteLogo.png"
             Height="72" HorizontalAlignment="Center"
             Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>

      <!-- Status message -->
      <TextBlock x:Name="StatusText"
                 Grid.Row="2"
                 Text="Loading your library…"
                 FontSize="12"
                 FontFamily="Segoe UI"
                 Foreground="#FFCDD3DA"
                 HorizontalAlignment="Center"/>

      <!-- Progress bar -->
      <ProgressBar x:Name="Bar"
                   Grid.Row="4"
                   Minimum="0" Maximum="100" Value="0"
                   IsIndeterminate="True"
                   Height="14"
                   Foreground="#FF4C6B8A"
                   Background="#FF0E1921"
                   BorderBrush="#FF4C6B8A"/>

      <!-- N of M counter -->
      <TextBlock x:Name="CounterText"
                 Grid.Row="6"
                 Text=""
                 FontSize="10"
                 FontFamily="Segoe UI"
                 Foreground="#FF8899AA"
                 HorizontalAlignment="Center"
                 Margin="0,4,0,0"/>

    </Grid>
  </Border>
</Window>
