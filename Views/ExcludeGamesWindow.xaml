<Window x:Class="SteamRoulette.Views.ExcludeGamesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exclude Games"
        Width="650" Height="580"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Search bar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
      <TextBlock x:Name="SearchLabel" Text="Search:" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <TextBox  x:Name="SearchBox"   Width="220" FontSize="11" Height="24"
                TextChanged="SearchBox_TextChanged"/>
    </StackPanel>

    <!-- Action buttons -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,6">
      <Button x:Name="BtnApply"     Content="Apply"        Width="70"  Height="26" Margin="0,0,6,0" Click="BtnApply_Click"/>
      <Button x:Name="BtnRefresh"   Content="Refresh List" Width="100" Height="26" Margin="0,0,6,0" Click="BtnRefresh_Click"/>
      <Button x:Name="BtnSelectAll" Content="Select All"   Width="90"  Height="26" Margin="0,0,6,0" Click="BtnSelectAll_Click"/>
      <Button x:Name="BtnClear"     Content="Clear All"    Width="80"  Height="26" Click="BtnClear_Click"/>
    </StackPanel>

    <!-- Game list -->
    <ListView x:Name="GameList"
              Grid.Row="2"
              Margin="6,0,6,4"
              SelectionMode="Multiple"
              MouseDoubleClick="GameList_DoubleClick"
              ScrollViewer.VerticalScrollBarVisibility="Auto">
      <ListView.View>
        <GridView>
          <GridViewColumn Width="30">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding IsExcluded, Mode=TwoWay}"
                          Checked="RowCheckBox_Changed"
                          Unchecked="RowCheckBox_Changed"/>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Width="26">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <Image Source="{Binding Icon}" Width="20" Height="20" Stretch="Uniform"/>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Game" DisplayMemberBinding="{Binding Name}" Width="520"/>
        </GridView>
      </ListView.View>
    </ListView>

    <!-- Status bar + icon download progress -->
    <Grid Grid.Row="3" Margin="8,2,8,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="180"/>
      </Grid.ColumnDefinitions>
      <TextBlock x:Name="StatusBar" Grid.Column="0"
                 FontSize="9" Foreground="Gray"
                 VerticalAlignment="Center" Text=""/>
      <StackPanel Grid.Column="1" VerticalAlignment="Center">
        <TextBlock x:Name="IconProgressLabel"
                   FontSize="9" Foreground="Gray"
                   HorizontalAlignment="Right"
                   Visibility="Collapsed" Text=""/>
        <ProgressBar x:Name="IconProgressBar"
                     Height="8" Minimum="0"
                     HorizontalAlignment="Stretch"
                     Visibility="Collapsed"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
