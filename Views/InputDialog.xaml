<Window x:Class="SteamRoulette.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Width="360" Height="155"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <StackPanel Margin="14">
    <TextBlock x:Name="PromptLabel" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="12"/>
    <TextBox x:Name="InputBox" Height="26" FontSize="12" Margin="0,0,0,8"/>
    <Button x:Name="SubmitBtn" Content="Submit" Width="90" Height="28"
            HorizontalAlignment="Right" Click="SubmitBtn_Click"/>
  </StackPanel>
</Window>
